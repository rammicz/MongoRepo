<?xml version="1.0" encoding="utf-8"?>

<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Rammi.MongoTypeRepository</id>
    <version>10.0.10</version>
    <title>Strongly typed Mongo / Cosmos repository</title>
    <authors>Jiri Hernik</authors>
    <owners>Jiri Hernik</owners>
	  <license type="expression">MIT</license>
    <projectUrl>https://github.com/rammicz/MongoRepo</projectUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <readme>docs\README.md</readme>
    <description>
		Provides strong types and repository access for mongoDB and Azure Cosmos DB, which is both weak typed.

		You can have all the sources with examples from here:
		https://github.com/rammicz/MongoRepo

		- Full async support
		- Async operation throttling to not overload the DB connection
	</description>
    <releaseNotes>
		- Fix: Delete(string) and DeleteAsync(string) silently no-op'd because the _id filter was built as a string instead of an ObjectId. Both overloads now parse to ObjectId before delegating to the working overload.
    </releaseNotes>
    <tags>mongodb mongo nosql azure cosmos cosmosdb repository strong-types strong type datamodel repo</tags>
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="MongoDB.Driver" version="3.5.2" />
      </group>
      <group targetFramework=".NETStandard2.1">
        <dependency id="MongoDB.Driver" version="3.5.2" />
      </group>
    </dependencies>
    <summary>
      Provides strong types (data model) and repository access for mongo DB or Azure CosmosDB

      Sources here:
      https://github.com/rammicz/MongoRepo
    </summary>
  </metadata>
  <files>
    <file src="bin/Release/net8.0/MongoTypeRepository.dll" target="lib/net8.0" />
    <file src="bin/Release/netstandard2.1/MongoTypeRepository.dll" target="lib/netstandard2.1" />
    <file src="README.md" target="docs\" />
  </files>
</package>
